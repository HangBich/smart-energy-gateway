# ==========================================
# Smart Energy Management Gateway - Config
# ==========================================

# MQTT
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=energy_user
MQTT_PASSWORD=energy_pass123

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=energy-super-secret-token-2026
INFLUXDB_ORG=smart-energy
INFLUXDB_BUCKET=energy_data
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin_pass_2026
INFLUXDB_ADMIN_TOKEN=energy-super-secret-token-2026

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=grafana_pass_2026

# Gateway
OVERLOAD_THRESHOLD_WATT=3500.0
SUMMARY_INTERVAL=5
METER_OFFLINE_TIMEOUT=30

# Smart Meters - publish interval in seconds
PUBLISH_INTERVAL=5

# HVAC Meter
HVAC_LOAD_ID=hvac
HVAC_DEVICE_ID=meter-hvac
HVAC_BASE_POWER=1200.0
HVAC_PRIORITY=low

# Lighting Meter
LIGHTING_LOAD_ID=lighting
LIGHTING_DEVICE_ID=meter-lighting
LIGHTING_BASE_POWER=400.0
LIGHTING_PRIORITY=medium

# Plug Meter
PLUG_LOAD_ID=plug
PLUG_DEVICE_ID=meter-plug
PLUG_BASE_POWER=800.0
PLUG_PRIORITY=low

# Solar Simulator
SOLAR_DEVICE_ID=solar-simulator
SOLAR_PEAK_POWER=1500.0
SOLAR_PUBLISH_INTERVAL=5

# API
API_HOST=0.0.0.0
API_PORT=8000
GATEWAY_STATE_FILE=/tmp/gateway_state.json
